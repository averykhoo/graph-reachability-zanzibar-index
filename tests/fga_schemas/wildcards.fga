model
  schema 1.1

type user

type group
  relations
    define member: [user, group#member]

type folder
  relations
    define parent: [folder]
    define viewer: [user, user:*, group#member, group:*#member] or viewer from parent

type document
  relations
    define parent: [folder]
    define viewer: [user, user:*, group#member, group:*#member] or viewer from parent
